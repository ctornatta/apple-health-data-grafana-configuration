          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 80,
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "value", "group": "A" }
          }
        },
        "overrides": []
      }
    },
