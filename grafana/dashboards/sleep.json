            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Sleep Stages per Night (hrs)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
          "query": "from(bucket: \"apple_health_metrics\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"sleep_phases\" and r._field == \"qty\") |> filter(fn: (r) => r.value == \"core\" or r.value == \"deep\" or r.value == \"rem\" or r.value == \"awake\") |> keep(columns: [\"_time\", \"_value\", \"value\"]) |> rename(columns: {value: \"_field\"}) |> group(columns: [\"_field\"])"
        }
      ],
      "options": {
