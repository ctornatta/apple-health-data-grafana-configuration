  "title": "Apple Health - Activity",
  "tags": ["apple-health"],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "1h",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Steps (Latest Day)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
          "query": "from(bucket: \"apple_health_metrics\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"step_count_count\" and r._field == \"qty\") |> aggregateWindow(every: 1d, fn: sum, createEmpty: false) |> last()"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "green", "value": 10000 }
            ]
          }
        },
        "overrides": []
      }
    },
