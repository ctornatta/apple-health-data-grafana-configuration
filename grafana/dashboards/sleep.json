{
  "id": null,
  "uid": "apple-health-sleep",
  "title": "Apple Health - Sleep",
  "tags": ["apple-health"],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "1h",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Avg Total Sleep (hrs)",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
          "query": "from(bucket: \"apple_health_metrics\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"sleep_phases\" and r._field == \"qty\") |> filter(fn: (r) => r.value == \"core\" or r.value == \"deep\" or r.value == \"rem\") |> pivot(rowKey: [\"_time\"], columnKey: [\"value\"], valueColumn: \"_value\") |> map(fn: (r) => ({_time: r._time, _value: (if exists r.core then r.core else 0.0) + (if exists r.deep then r.deep else 0.0) + (if exists r.rem then r.rem else 0.0), _field: \"total_sleep_hrs\"})) |> group() |> mean()"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 6 },
              { "color": "green", "value": 7 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg Deep Sleep (hrs)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
