{
  "id": null,
  "uid": "apple-health-food-log",
  "title": "Apple Health - Food Log",
  "tags": ["apple-health"],
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-30d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Meals Logged",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
          "query": "from(bucket: \"food_log\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"food_intake\" and r._field == \"logged\") |> count() |> group() |> sum()"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Healthy Meals (%)",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
          "query": "from(bucket: \"food_log\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"food_intake\" and r._field == \"logged\") |> group() |> map(fn: (r) => ({r with _value: if r.is_healthy == \"yes\" then 1.0 else 0.0})) |> mean() |> map(fn: (r) => ({r with _value: r._value * 100.0}))"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 70 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Overeating (%)",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
          "query": "from(bucket: \"food_log\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"food_intake\" and r._field == \"logged\") |> group() |> map(fn: (r) => ({r with _value: if r.did_overeat == \"yes\" then 1.0 else 0.0})) |> mean() |> map(fn: (r) => ({r with _value: r._value * 100.0}))"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Meals per Day by Type",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
          "query": "from(bucket: \"food_log\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"food_intake\" and r._field == \"logged\") |> aggregateWindow(every: 1d, fn: count, createEmpty: false) |> map(fn: (r) => ({r with _field: r.meal_type})) |> group(columns: [\"_field\"])"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "displayName": "${__field.labels._field}",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 80,
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "value", "group": "A" }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Daily Healthy vs Unhealthy Meals",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
          "query": "from(bucket: \"food_log\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"food_intake\" and r._field == \"logged\" and r.is_healthy == \"yes\") |> aggregateWindow(every: 1d, fn: count, createEmpty: false) |> map(fn: (r) => ({r with _field: \"Healthy\"})) |> group(columns: [\"_field\"])"
        },
        {
          "refId": "B",
          "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
          "query": "from(bucket: \"food_log\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"food_intake\" and r._field == \"logged\" and r.is_healthy == \"no\") |> aggregateWindow(every: 1d, fn: count, createEmpty: false) |> map(fn: (r) => ({r with _field: \"Unhealthy\"})) |> group(columns: [\"_field\"])"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "displayName": "${__field.labels._field}",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 80,
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "value", "group": "A" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Healthy" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Unhealthy" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Overeating Incidents per Day",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
          "query": "from(bucket: \"food_log\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"food_intake\" and r._field == \"logged\" and r.did_overeat == \"yes\") |> aggregateWindow(every: 1d, fn: count, createEmpty: false) |> group()"
        }
      ],
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 80,
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "none", "group": "A" }
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Food Log Entries",
      "description": "All logged meals in the selected time range, newest first. Description only visible here.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "apple-health-influxdb" },
          "query": "from(bucket: \"food_log\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"food_intake\" and r._field == \"description\") |> group() |> rename(columns: {_value: \"description\"}) |> keep(columns: [\"_time\", \"meal_type\", \"is_healthy\", \"did_overeat\", \"description\"]) |> sort(columns: [\"_time\"], desc: true)"
        }
      ],
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "_time" },
            "properties": [{ "id": "unit", "value": "dateTimeAsLocal" }]
          }
        ]
      }
    }
  ]
}
